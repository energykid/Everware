		Tooltip: ""
	}

	BloodRubyCharm: {
		DisplayName: Рубин дьявола
		Tooltip:
			'''
			Нажмите дважды в нужном направлении, чтобы совершить взрывной рывок, наносящий урон врагам
			Рывок также ненадолго задерживает вас в воздухе
			'''
	}

	Pyrocleavers: {
		DisplayName: Пироруб
		Tooltip:
			'''
			Бросает раскалённый топор, который расплавляется при контакте с землёй, оставляя за собой лаву
			Отскакивает при попадании в стену
			'''
	}

	SkullStaff: {
		DisplayName: Посох обсидианового черепа
		Tooltip:
			'''
			Призывает ужасающий, смеющийся, кричащий обсидиановый череп, взрывающийся при контакте с врагом
			Медленно восстанавливается после попадания по врагу
			'''
	}

	HotShot: {
		DisplayName: Огнестрел
		Tooltip:
			'''
			Нажмите ПКМ, чтобы зарядить оружие
			Каждый уровень заряда выпускает больше пуль, а также имеет большую скорость и меньший разброс
			Три зарядки подряд максимально заряжают выстрел и вызывают сильную отдачу при атаке
			'''
	}

	UnwieldyStaff: {
		DisplayName: Громоздкий посох
		Tooltip: После долгой зарядки, вызывает три магических шипа из-под земли
	}

	BookOfBoulders: {
		DisplayName: Книга валунов
		Tooltip: Призывает над курсором раздавливающий врагов валун
	}

	MagmaticGlowcoat: {
		DisplayName: Магматическое светящиеся покрытие
		Tooltip: Используйте на блоках, чтобы они начали излучать мягкий магматический свет
	}
}

