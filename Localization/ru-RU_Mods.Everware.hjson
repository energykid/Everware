	}

	Rebuker: {
		DisplayName: Упрекатель
		Tooltip:
			'''
			Стреляет пробивающей врагов арматурой
			Арматура наносит меньше урона с каждой последующей поражённой целью
			'''
	}

	KilnMusicBox: {
		DisplayName: Музыкальная шкатулка (Обжигальня)
		Tooltip: ""
