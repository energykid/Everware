	BloodRubyCharm: {
		DisplayName: Devil's Ruby
		Tooltip:
			'''
			Double tap a direction to dash, creating a damaging explosion behind you
			Dashing also briefly stops you from falling
			'''
	}

	Pyrocleavers: {
		DisplayName: Pyrocleavers
		Tooltip:
			'''
			Throws molten cleavers that melt into the floor, leaving lingering lava
			If hitting a wall, the cleavers will bounce off of it
			'''
	}

	SkullStaff: {
		DisplayName: Obsidian Skull Staff
		Tooltip:
			'''
			Summons a terrifying, laughing, screaming obsidian skull that explodes on contact
			Regenerates shortly after hitting an enemy
			'''
	}

	HotShot: {
		DisplayName: Hot Shot
		Tooltip:
			'''
			Right click to pump, increasing bullet count and speed while reducing spread
			Three consecutive pumps before firing maxes your charge and causes heavy recoil when attacking
			'''
	}

	UnwieldyStaff: {
		DisplayName: Unwieldy Staff
		Tooltip: After a long buildup, summons three magic spikes from the ground
	}

	BookOfBoulders: {
		DisplayName: Book of Boulders
		Tooltip: Conjures a boulder from above your cursor to crash down on your foes
	}

	MagmaticGlowcoat: {
		DisplayName: Magmatic Glowcoat
		Tooltip: Apply to a tile to give it a deep magmatic glow
	}
